{
  "name": "youtube-scheduler",
  "productName": "YouTube Scheduler",
  "version": "0.1.0",
  "description": "Schedule recurring YouTube live broadcasts from a friendly desktop app.",
  "author": "bkntr",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/bkntr/youtube-scheduler.git"
  },
  "homepage": "https://github.com/bkntr/youtube-scheduler",
  "bugs": "https://github.com/bkntr/youtube-scheduler/issues",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "ui:fixtures": "vite --config vite.renderer.config.ts",
    "start": "electron-vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run typecheck && npm test && electron-vite build",
    "dist:win:x64": "npm run build && electron-builder --win nsis --x64",
    "dist:win:arm64": "npm run build && electron-builder --win nsis --arm64",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --arm64"
  },
  "dependencies": {
    "@googleapis/youtube": "^33.0.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@lucide/svelte": "^0.544.0",
    "bits-ui": "^2.18.1",
    "electron-log": "^5.4.3",
    "googleapis-common": "8.0.2",
    "svelte": "^5.38.10",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.3.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "svelte-check": "^4.3.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.bkntr.youtube-scheduler",
    "productName": "YouTube Scheduler",
    "asar": true,
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "artifactName": "YouTube-Scheduler-${version}-${arch}-Setup.${ext}",
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "useZip": true,
      "differentialPackage": false,
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YouTube Scheduler",
      "deleteAppDataOnUninstall": false
    }
  },
  "allowScripts": {
    "electron": true,
    "esbuild": true,
    "electron-winstaller": true
  }
}
